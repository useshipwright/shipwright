# Firebase Client SDK config (from Firebase Console > Project Settings > Web App)
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id

# URL of the Firebase Auth Fastify service
FIREBASE_AUTH_SERVICE_URL=http://localhost:8080

# API key for authenticating with the service (must match API_KEYS in service .env)
FIREBASE_AUTH_SERVICE_API_KEY=your-api-key-here

# Optional: Firebase Auth Emulator for local dev
# NEXT_PUBLIC_FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
