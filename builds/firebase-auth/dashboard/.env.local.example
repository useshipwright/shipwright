# Firebase Client SDK config (from Firebase Console > Project Settings > Web App)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=firebase-auth-demo.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=firebase-auth-demo

# Set to use Firebase Auth Emulator for local dev (docker-compose)
NEXT_PUBLIC_FIREBASE_AUTH_EMULATOR_HOST=localhost:9099

# URL of the Firebase Auth Fastify service
# Local: http://localhost:8080
# Cloud Run: https://firebase-auth-<hash>.us-central1.run.app
FIREBASE_AUTH_SERVICE_URL=http://localhost:8080
