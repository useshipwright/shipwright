# Firebase Admin SDK service account JSON credential (required)
# Provided via Secret Manager in production
FIREBASE_SERVICE_ACCOUNT_JSON=

# HTTP port (default: 8080)
PORT=8080

# GCP project ID for deployment
GCP_PROJECT_ID=

# GCP region for Cloud Run deployment
GCP_REGION=

# Valid Firebase ID token for smoke tests (optional)
# If not provided, smoke tests degrade to health-only
FIREBASE_TEST_ID_TOKEN=
